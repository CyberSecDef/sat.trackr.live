# =============================================================================
# .env.prod — Production overlay (loaded after .env when APP_ENV=prod)
# =============================================================================
# Copy this file to .env.prod on the production host. Real .env.prod is
# gitignored and must NEVER be committed — it holds real credentials.
# =============================================================================

# Path to the SQLite database. Use an absolute path on prod for clarity.
DB_PATH="/home/user/sat.trackr.live/data/sat.db"

# Cesium ion token (production). Required for ion-hosted imagery & terrain.
# If empty, falls back to OpenStreetMap (still works, less polished).
CESIUM_ION_TOKEN=""

# Vite dev origin is irrelevant in prod — assets are served from public/build/
# by Apache directly. Leave unset.

# --- API credentials (uncomment as features come online in later phases) ---

# Space-Track.org (Phase 2)
# SPACE_TRACK_USER=""
# SPACE_TRACK_PASS=""

# N2YO API (Phase 2)
# N2YO_API_KEY=""

# Launch Library 2 (Phase 2)
# LL2_API_TOKEN=""
