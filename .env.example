# =============================================================================
# .env — Base configuration (shared between dev and prod)
# =============================================================================
# This file is loaded FIRST by EnvLoader. It provides defaults and the APP_ENV
# marker. After this file loads, .env.{APP_ENV} overlays environment-specific
# values (DB paths, API keys, etc).
#
# Copy this file to .env and edit as needed. Real .env files are gitignored.
# =============================================================================

# Which environment overlay to load: dev or prod.
# - dev  -> overlays .env.dev
# - prod -> overlays .env.prod
APP_ENV=dev

# Human-readable name (used in <title>, OG tags, footer)
APP_NAME="sat.trackr.live"

# Base URL where this app is served. No trailing slash.
APP_URL="http://localhost:8000"

# Log verbosity: debug | info | notice | warning | error | critical
LOG_LEVEL=info
