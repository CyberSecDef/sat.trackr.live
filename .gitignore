# PHP / Composer
/vendor/
composer.phar

# Node
/node_modules/

# Build artifacts (regenerated by `make build`)
/public/build/
/public/cesium/
# Sitemap output — regenerated by `make sitemap-build` / daily cron (Phase 5 chunk 5)
/public/sitemap.xml
/public/sitemap-*.xml

# Environment files — templates committed (.env*.example), real files ignored
/.env
/.env.dev
/.env.prod

# SQLite database files
/data/*.db
/data/*.db-shm
/data/*.db-wal

# Runtime logs and caches
/storage/logs/*
!/storage/logs/.gitkeep
/storage/cache/*
!/storage/cache/.gitkeep

# Tooling caches
/.phpunit.cache/
/.phpunit.result.cache
/.php-cs-fixer.cache
/.phpstan.cache/

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/

# IDE / editor
/.idea/
/.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
